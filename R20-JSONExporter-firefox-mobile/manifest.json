{
  "manifest_version": 2,
  "name": "R20-JSONExporter Mobile",
  "version": "0.9.0",
  "description": "Export a Roll20 chat to JSON on Android.",
  "browser_action": {
    "default_title": "R20-JSONExporter"
  },
  "background": {
    "scripts": [
      "js/background/background.js"
    ]
  },
  "permissions": [
    "storage",
    "clipboardWrite",
    "downloads",
    "tabs",
    "activeTab",
    "https://*.roll20.net/*",
    "https://roll20.net/*",
    "https://*.d20.io/*",
    "https://d20.io/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.roll20.net/*",
        "https://roll20.net/*"
      ],
      "js": [
        "js/content/export/avatar_rules.js",
        "js/content/export/avatar_export_resolution.js",
        "js/content/export/avatar_link_meta.js",
        "js/content/export/message_context_parser.js",
        "js/content/export/parsers/parser_utils.js",
        "js/content/export/parsers/coc/coc_rule_parser.js",
        "js/content/export/parsers/insane/insane_rule_parser.js",
        "js/content/export/chat_json_export.js",
        "js/content/core/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "r20-json-exporter-firefox@reha.dev",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  }
}
