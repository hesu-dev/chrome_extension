{
  "manifest_version": 2,
  "name": "R20-JSONExporter Firefox Mobile",
  "version": "0.1.0",
  "description": "Export a Roll20 chat to JSON on Firefox for Android.",
  "browser_action": {
    "default_title": "R20-JSONExporter",
    "default_popup": "popup.html"
  },
  "background": {
    "scripts": [
      "js/background/background.js"
    ]
  },
  "permissions": [
    "storage",
    "downloads",
    "tabs",
    "activeTab",
    "https://*.roll20.net/*",
    "https://roll20.net/*",
    "https://*.d20.io/*",
    "https://d20.io/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.roll20.net/*",
        "https://roll20.net/*"
      ],
      "js": [
        "js/content/export/parsers/parser_utils.js",
        "js/content/export/parsers/coc/coc_rule_parser.js",
        "js/content/export/parsers/insane/insane_rule_parser.js",
        "js/content/export/chat_json_export.js",
        "js/content/core/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "r20-json-exporter-firefox-mobile@local",
      "gecko_android": {
        "strict_min_version": "120.0"
      }
    }
  }
}
