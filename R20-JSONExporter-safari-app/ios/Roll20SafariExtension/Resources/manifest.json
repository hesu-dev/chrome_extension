{
  "manifest_version": 3,
  "name": "리딩로그: 파일 가져오기",
  "version": "0.8.1",
  "description": "Safiri 확장을 통해, Roll20 채팅 로그를 리딩로그로 복사합니다.",
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "scripts": [
      "js/background/background.js"
    ],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": [
        "https://app.roll20.net/*"
      ],
      "js": [
        "js/vendor/roll20-json-core.js",
        "js/avatar_export_resolution.js",
        "js/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "js/page_avatar_resolver.js"
      ],
      "matches": [
        "https://app.roll20.net/*"
      ]
    }
  ],
  "permissions": [
    "tabs",
    "nativeMessaging"
  ],
  "host_permissions": [
    "https://*.roll20.net/*",
    "https://roll20.net/*",
    "https://*.d20.io/*",
    "https://d20.io/*",
    "https://*.amazonaws.com/*",
    "https://*.gravatar.com/*",
    "https://gravatar.com/*"
  ]
}
