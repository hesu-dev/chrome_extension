{
  "manifest_version": 3,
  "name": "R20 Safari Export",
  "version": "0.7.0",
  "description": "Standalone Safari export scaffold for Roll20 chat JSON.",
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://app.roll20.net/*"
      ],
      "js": [
        "js/vendor/roll20-json-core.js",
        "js/avatar_export_resolution.js",
        "js/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "tabs",
    "nativeMessaging"
  ]
}
